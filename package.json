{
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "bun test",
    "test:integration": "bun test tests/",
    "test:core": "bun test --cwd packages/govdata-core",
    "test:doge": "bun test --cwd packages/doge-api",
    "test:naics": "bun test --cwd packages/naics-api",
    "test:dol": "bun test --cwd packages/dol-open-data-api",
    "test:fr": "bun test --cwd packages/federal-register",
    "test:usaspending": "bun test --cwd packages/usaspending-api",
    "test:bls": "bun test --cwd packages/bls-api",
    "typecheck": "tsc -b packages/govdata-core packages/doge-api packages/naics-api packages/dol-open-data-api packages/federal-register packages/usaspending-api packages/bls-api packages/govdata-cli packages/govdata-mcp",
    "build": "bun build packages/govdata-cli/src/cli.ts --compile --outfile dist/govdata && bun build packages/govdata-mcp/src/mcp.ts --compile --outfile dist/govdata-mcp",
    "build:cli": "bun build packages/govdata-cli/src/cli.ts --compile --outfile dist/govdata",
    "build:mcp": "bun build packages/govdata-mcp/src/mcp.ts --compile --outfile dist/govdata-mcp"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "govdata-core": "workspace:*",
    "doge-api": "workspace:*",
    "naics-api": "workspace:*",
    "dol-open-data-api": "workspace:*",
    "federal-register": "workspace:*",
    "usaspending-api": "workspace:*",
    "bls-api": "workspace:*",
    "typescript": "^5.7",
    "zod": "^4.3"
  }
}
